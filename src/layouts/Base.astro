---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Tetrazero - William Michaud',
	description = 'Portfolio of William Michaud, CS engineering student at INSA Lyon (class of 2027), consultant and CTO at Buddimm, competitive programmer (2nd in France, ICPC European Championship).',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="William Michaud, Computer Science, Competitive Programming, Algorithms, Python, C++, Web Development, Full-stack development, Consulting, Software Engineering, Application Security, AI Automation"
		/>
		<meta name="author" content="William Michaud" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://tetrazero.com" />
		<link rel="canonical" href="https://tetrazero.com" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600&family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="grain antialiased">
		<slot />
	</body>
</html>
