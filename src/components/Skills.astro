---
import Container from './Container.astro';
import SectionHeader from './SectionHeader.astro';
import skills from '../data/skills.json';
---

<section id="skills" class="relative overflow-hidden border-t border-line py-24 md:py-32">
	<Container>
		<SectionHeader index="04" label="Toolbox" title="Skills" />

		<div class="space-y-14">
			{
				skills.map((group, i) => (
					<div data-reveal>
						<div class="mb-6 flex items-baseline gap-4">
							<span class="font-mono text-xs tracking-[0.25em] uppercase text-muted">
								04<span class="text-acid">.</span>{i + 1}
							</span>
							<h3 class="font-display text-xl font-extrabold tracking-tight uppercase md:text-2xl">
								{group.group}
							</h3>
							<span class="hidden h-px flex-1 bg-line md:block" />
						</div>

						<ul class="grid grid-cols-2 gap-px sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7">
							{group.items.map((item) => (
								<li class="group flex min-w-0 items-center gap-3 bg-night px-4 py-3.5 shadow-[0_0_0_1px_var(--color-line)] transition-colors hover:bg-surface">
									<img
										src={`/tech_icons/${item.icon}`}
										alt=""
										width="22"
										height="22"
										loading="lazy"
										class="h-[22px] w-[22px] opacity-70 transition-opacity group-hover:opacity-100"
									/>
									<span class="truncate font-mono text-xs tracking-wide text-muted transition-colors group-hover:text-ink">
										{item.name}
									</span>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</Container>
</section>
