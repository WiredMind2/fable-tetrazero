---
import Container from './Container.astro';
import AcidText from './AcidText.astro';
---

<section class="border-t border-line bg-raised py-16 md:py-20">
	<Container>
		<div
			data-reveal
			class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:text-left"
		>
			<div>
				<p class="kicker mb-3">Open to opportunities</p>
				<h2 class="font-display text-2xl font-bold md:text-3xl">
					Download my resume<span class="text-acid">.</span>
				</h2>
				<AcidText
					as="p"
					class="mt-3 max-w-xl text-muted"
					text="One-page PDF - experience, skills, and contact details."
				/>
			</div>
			<a href="/Resume.pdf" download rel="noopener noreferrer" class="btn-acid shrink-0">
				Download resume
			</a>
		</div>
	</Container>
</section>
