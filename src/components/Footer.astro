---
import Container from './Container.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-line">
	<Container
		class="flex flex-col items-start justify-between gap-6 py-10 md:flex-row md:items-center"
	>
		<div class="font-mono text-xs tracking-[0.2em] text-muted uppercase">
			&copy; {year} William Michaud - Tetra<span class="text-acid">zero</span>
		</div>

		<div class="flex items-center gap-6 font-mono text-xs tracking-[0.15em] uppercase">
			<a href="/privacy" class="text-muted transition-colors hover:text-acid">Privacy</a>
			<a href="/terms" class="text-muted transition-colors hover:text-acid">Terms</a>
			<a
				href="https://github.com/WiredMind2/tetrazero"
				target="_blank"
				rel="noopener noreferrer"
				class="text-muted transition-colors hover:text-acid">Source</a
			>
		</div>
	</Container>
</footer>
