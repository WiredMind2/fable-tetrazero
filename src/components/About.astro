---
import Container from './Container.astro';
import SectionHeader from './SectionHeader.astro';

const details = [
	{
		title: 'Competitive Programming',
		text: 'I compete regularly in computer science contests. My team ranked 2nd in France and 40th in Europe at the 2026 ICPC European Championship, and we will compete again at SWERC 2026.',
	},
	{
		title: 'Background',
		text: 'Computer science engineering student at INSA Lyon, one of France\u2019s top engineering schools, graduating in June 2027. Alongside my studies I lead multiple student associations, including INSAlgo as president. At Buddimm, I lead the technical stack; recent consulting includes security assessment at Profundum AI and algorithm modernization at BOBST.',
	},
	{
		title: 'Languages & Interests',
		text: 'I speak five languages: French (native), Creole (native), English (C2), German (B2) and Japanese (JLPT N4). Off the keyboard: mathematics, video games, the gym and running.',
	},
];
---

<section id="about" class="relative overflow-hidden py-24 md:py-32">
	<Container>
		<SectionHeader index="01" label="Get To Know Me" title="About" />

		<div class="grid gap-14 md:grid-cols-12">
			<div data-reveal class="md:col-span-5">
				<p class="font-display text-2xl leading-snug font-bold md:text-3xl">
					Hey there, I'm William, I write code for work, for sport, and for fun<span
						class="text-acid">.</span
					>
				</p>
				<p class="mt-6 leading-relaxed text-muted md:text-lg">
					I build things ranging from compilers and trading systems to three-player chess engines,
					all open-source on my GitHub. I've also consulted on engineering, AI automation, and
					cybersecurity: from porting production algorithms to rolling out AI workflows and auditing
					AI SaaS platforms. When I'm not shipping side projects, I'm grinding algorithm problems
					or designing contest exercises for others to solve.
				</p>
				<a
					href="/Resume.pdf"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-ghost mt-8 inline-block">Resume ↗</a
				>
			</div>

			<div class="space-y-px border border-line bg-line md:col-span-7">
				{
					details.map((detail, i) => (
						<div data-reveal class="bg-surface p-7 md:p-8">
							<div class="flex items-baseline gap-4">
								<span class="font-mono text-xs tracking-[0.25em] text-acid">01.{i + 1}</span>
								<h3 class="font-display text-lg font-extrabold tracking-tight uppercase">
									{detail.title}
								</h3>
							</div>
							<p class="mt-3 leading-relaxed text-muted">{detail.text}</p>
						</div>
					))
				}
			</div>
		</div>
	</Container>
</section>
