---
import { getCollection } from 'astro:content';
import Container from './Container.astro';
import SectionHeader from './SectionHeader.astro';
import AcidText from './AcidText.astro';

const idOrder = [
	'buddimm',
	'profundum-security',
	'bobst',
	'competitions',
	'vr-research',
	'npu-carbon-fiber',
	'insa-lyon',
	'leadership',
];

const groupLabel = {
	work: 'Professional',
	competition: 'Competition',
	research: 'Research',
	leadership: 'Leadership',
	education: 'Education',
} as const;

const experiences = (await getCollection('experiences'))
	.map((entry) => entry.data)
	.sort((a, b) => {
		const rank = (id: string) => {
			const i = idOrder.indexOf(id);
			return i === -1 ? idOrder.length : i;
		};
		return rank(a.id) - rank(b.id);
	});
---

<section id="experience" class="relative overflow-hidden border-t border-line bg-surface py-24 md:py-32">
	<Container class="relative">
		<SectionHeader index="03" label="Track Record" title="Experience" />

		<div class="relative">
			<div
				class="grid-field grid-field--body pointer-events-none absolute top-0 -bottom-24 left-1/2 w-screen -translate-x-1/2 md:-bottom-32"
				aria-hidden="true"></div>

			<ol class="relative">
			<span
				class="experience-timeline pointer-events-none absolute inset-y-0 left-2 w-1 md:left-1/2 md:-translate-x-1/2"
				aria-hidden="true"></span>

			{
				experiences.map((exp, i) => (
					<li
						data-reveal
						class:list={[
							'experience-item relative pb-16 pl-8 last:pb-0 md:pl-0',
							i % 2 === 0 ? 'experience-item--left md:w-1/2 md:pr-12 lg:pr-16' : 'experience-item--right md:ml-auto md:w-1/2 md:pl-12 lg:pl-16',
							i > 0 && 'md:-mt-20 lg:-mt-32',
						]}
					>
						<span
							class:list={[
								'experience-item-marker absolute top-1.5 left-[5.5px] h-[9px] w-[9px] rotate-45 bg-acid',
								i % 2 === 0
									? 'md:left-auto md:right-0 md:translate-x-1/2'
									: 'md:left-0 md:-translate-x-1/2',
							]}
						/>

						<div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
							{exp.period && (
								<span class="font-mono text-xs tracking-[0.2em] text-acid uppercase">
									{exp.period}
								</span>
							)}
							<span class="font-mono text-xs tracking-[0.2em] text-muted/60 uppercase">
								{groupLabel[exp.group]}
							</span>
						</div>

						<h3 class="mt-3 font-display text-xl font-extrabold tracking-tight uppercase md:text-2xl">
							{exp.title}
						</h3>
						<p class="mt-1 font-mono text-sm text-muted">{exp.org}</p>
						<AcidText as="p" class="mt-4 max-w-2xl leading-relaxed text-muted" text={exp.description} />

						{exp.achievements.length > 0 && (
							<ul class="mt-5 space-y-2.5">
								{exp.achievements.map((achievement) => (
									<li class="flex max-w-2xl items-start gap-3 text-sm leading-relaxed text-ink/85 md:text-base">
										<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-acid" />
										<AcidText as="span" text={achievement} />
									</li>
								))}
							</ul>
						)}

						{exp.technologies.length > 0 && (
							<div class="mt-6 flex flex-wrap gap-2">
								{exp.technologies.map((tech) => (
									<span class="tag">{tech}</span>
								))}
							</div>
						)}
					</li>
				))
			}
		</ol>
		</div>
	</Container>
</section>
