---
import Container from './Container.astro';

const links = [
	{ href: '#about', label: 'About' },
	{ href: '#projects', label: 'Projects' },
	{ href: '#experience', label: 'Experience' },
	{ href: '#skills', label: 'Skills' },
	{ href: '#contact', label: 'Contact' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-night/80 backdrop-blur-md">
	<Container class="flex h-16 items-center justify-between">
		<a href="#top" class="shrink-0 font-mono text-sm font-semibold tracking-[0.25em] text-ink uppercase">
			Tetra<span class="text-acid">zero</span>
		</a>

		<div id="nav-links" class="relative hidden items-center gap-5 lg:flex lg:gap-8">
			<ul class="flex items-center gap-5 lg:gap-8">
				{
					links.map((link, i) => (
						<li>
							<a
								href={link.href}
								data-nav-link
								data-section={link.href.slice(1)}
								class="nav-link font-mono text-xs tracking-[0.18em] uppercase"
							>
								<span class="nav-link-prefix">0{i + 1}<span class="text-acid">.</span></span> {link.label}
							</a>
						</li>
					))
				}
			</ul>
			<span
				id="nav-indicator"
				class="pointer-events-none absolute bottom-0 left-0 h-px bg-acid opacity-0"
				aria-hidden="true"
			></span>
			<a
				href="/Resume.pdf"
				target="_blank"
				rel="noopener noreferrer"
				class="border border-acid/60 px-3.5 py-1.5 font-mono text-xs tracking-[0.18em] text-acid uppercase transition-colors hover:bg-acid hover:text-night"
			>
				Resume ↗
			</a>
		</div>

		<button
			id="nav-toggle"
			class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 lg:hidden"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<span class="nav-bar block h-px w-6 bg-ink transition-transform"></span>
			<span class="nav-bar block h-px w-6 bg-ink transition-opacity"></span>
			<span class="nav-bar block h-px w-6 bg-ink transition-transform"></span>
		</button>
	</Container>

	<div id="nav-menu" class="hidden border-t border-line bg-night lg:hidden">
		<ul class="flex flex-col px-5 py-4">
			{
				links.map((link, i) => (
					<li>
						<a
							href={link.href}
							data-nav-link
							data-section={link.href.slice(1)}
							class="nav-link block py-3 font-mono text-sm tracking-[0.18em] uppercase"
						>
							<span class="nav-link-prefix">0{i + 1}<span class="text-acid">.</span></span> {link.label}
						</a>
					</li>
				))
			}
			<li>
				<a
					href="/Resume.pdf"
					target="_blank"
					rel="noopener noreferrer"
					class="block py-3 font-mono text-sm tracking-[0.18em] text-acid uppercase"
				>
					Resume ↗
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const toggle = document.getElementById('nav-toggle')!;
	const menu = document.getElementById('nav-menu')!;

	toggle.addEventListener('click', () => {
		const open = menu.classList.toggle('hidden') === false;
		toggle.setAttribute('aria-expanded', String(open));
	});

	menu.querySelectorAll('a').forEach((a) =>
		a.addEventListener('click', () => {
			menu.classList.add('hidden');
			toggle.setAttribute('aria-expanded', 'false');
		})
	);
</script>
